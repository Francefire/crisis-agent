# Copy to .env and fill in. NEVER commit real keys.

# Which LLM provider to use: gemini | groq | mistral
LLM_PROVIDER=gemini
# Optional: override the model for the chosen provider.
# LLM_MODEL=

# Optional second provider: every LLM call fails over to it on error/rate-limit,
# so one pipeline run can span TWO providers' quotas. Leave empty to disable.
# Tip: put the more generous provider as LLM_PROVIDER and the other here.
# LLM_FALLBACK_PROVIDER=mistral

# Optional: explicit provider PRIORITY (overrides LLM_PROVIDER/_FALLBACK_PROVIDER and
# config.yaml `llm.provider_priority`). Comma/space separated, best-first. A call
# walks this order, so one run can span several providers' quotas.
# LLM_PROVIDER_PRIORITY=deepseek,groq,mistral,gemini

# --- rate limiting (free tiers cap tokens/minute; the orchestrator runs 3 stages) ---
# Shared throttle across all pipeline stages. Lower = safer on strict free tiers.
# LLM_RPS=0.5          # requests/second (0.5 = 1 call every 2s)
# LLM_MAX_RETRIES=6    # same-key retries (backoff) for RPM/RPD limits & 5xx

# --- keys (only the one for LLM_PROVIDER is required) ---
# Each key var may hold ONE key or SEVERAL (comma / space / newline separated) —
# a call rotates to the next key when the current one hits its TOKEN quota
# (tokens-per-minute/day). A requests-per-interval limit (RPM/RPD) instead waits
# and retries on the same key. So listing N keys ~multiplies your daily TOKEN
# budget by N. `<PROVIDER>_API_KEYS` (plural) works too, if you prefer.
#   e.g.  GEMINI_API_KEY=AIza...one,AIza...two,AIza...three
# A key may carry an inline PRIORITY as "key|N" (lower N = tried first; unannotated
# keys keep their listed order). Handy to prefer a fresher/paid key:
#   e.g.  GROQ_API_KEY=old...key|1,new...key|0   (new key tried first)
# Gemini (free): https://aistudio.google.com/app/apikey
#   NOTE: restricted free projects cap at ~20 requests/day PER MODEL.
GEMINI_API_KEY=
# Groq (free, generous daily quota, great tool-calling): https://console.groq.com/keys
GROQ_API_KEY=
# Mistral (free experimental tier): https://console.mistral.ai/
MISTRAL_API_KEY=
